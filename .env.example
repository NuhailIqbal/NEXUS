# ─── Frontend (Vite) ───
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_API_URL="http://localhost:8000"
VITE_API_PUBLIC_URL=""           # leave blank in dev; set to your prod backend URL for embed snippets
VITE_VAPI_PUBLIC_KEY=""          # VAPI public key — used by the in-dashboard "Talk to Agent" web call

# ─── Backend (FastAPI) ───
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# VAPI
VAPI_API_KEY=""             # private/server key from VAPI dashboard
VAPI_PUBLIC_KEY=""          # public/web-SDK key — embedded in voice-widget embed.js
VAPI_WEBHOOK_SECRET=""      # REQUIRED in production — VAPI signs webhooks with this

# Gemini (post-call AI summaries)
GEMINI_API_KEY=""

# Server config
CORS_ORIGINS="http://localhost:5173,http://localhost:3000,http://localhost:8080"
PUBLIC_API_URL=""           # publicly reachable URL of this backend — used in VAPI tool callbacks. e.g. https://api.yourdomain.com
